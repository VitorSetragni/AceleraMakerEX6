       >>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. GERAR-RELATORIO-FINAL.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ARQ-LOG ASSIGN TO "saida/LOG_RELATORIO_FINAL.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD ARQ-LOG.
01 REG-LOG PIC X(250).

WORKING-STORAGE SECTION.
01 WS-LINHA                 PIC X(250) VALUE SPACES.
01 WS-CAMINHO-CLIENTES      PIC X(100) VALUE "saida/REL_FINAL_DB_CLIENTES.TXT".
01 WS-CAMINHO-ERROS         PIC X(100) VALUE "saida/REL_FINAL_DB_ERROS.TXT".

COPY "variaveis_banco.cpy".

PROCEDURE DIVISION.
INICIO.
    OPEN OUTPUT ARQ-LOG

    MOVE "INICIO DO RELATORIO FINAL CONSULTANDO O DB2" TO WS-LINHA
    WRITE REG-LOG FROM WS-LINHA

    CALL "BANCO_CONECTAR" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
    PERFORM GRAVAR-MENSAGEM-DB2

    IF WS-RC-BANCO = ZERO
        CALL "BANCO_GERAR_RELATORIO_CLIENTES" USING
            WS-CAMINHO-CLIENTES
            WS-MSG-BANCO
            RETURNING WS-RC-BANCO
        END-CALL
        PERFORM GRAVAR-MENSAGEM-DB2

        CALL "BANCO_GERAR_RELATORIO_ERROS" USING
            WS-CAMINHO-ERROS
            WS-MSG-BANCO
            RETURNING WS-RC-BANCO
        END-CALL
        PERFORM GRAVAR-MENSAGEM-DB2

        CALL "BANCO_DESCONECTAR" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
    END-IF

    MOVE "FIM DO RELATORIO FINAL" TO WS-LINHA
    WRITE REG-LOG FROM WS-LINHA

    CLOSE ARQ-LOG
    STOP RUN.

GRAVAR-MENSAGEM-DB2.
    MOVE SPACES TO WS-LINHA
    STRING "DB2: " WS-MSG-BANCO DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-LOG FROM WS-LINHA.

END PROGRAM GERAR-RELATORIO-FINAL.
