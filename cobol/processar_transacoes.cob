       >>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. PROCESSAR-TRANSACOES.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ARQ-TRANSACOES ASSIGN TO "entrada/TRANSACOES_ORD.TXT"
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS FS-TRANSACOES.

    SELECT ARQ-STATUS ASSIGN TO "saida/SAIDA_STATUS_TRANSACOES.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-DETALHADO ASSIGN TO "saida/REL_DETALHADO_TRANSACOES.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-RELATORIO ASSIGN TO "saida/REL_PROCESSAMENTO_TRANSACOES.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-ERROS ASSIGN TO "saida/ERROS_TRANSACOES.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-LOG ASSIGN TO "saida/LOG_TRANSACOES.TXT"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD ARQ-TRANSACOES.
COPY "registro_transacao.cpy".

FD ARQ-STATUS.
01 REG-STATUS PIC X(250).

FD ARQ-DETALHADO.
01 REG-DETALHADO PIC X(250).

FD ARQ-RELATORIO.
01 REG-RELATORIO PIC X(250).

FD ARQ-ERROS.
01 REG-ERROS PIC X(250).

FD ARQ-LOG.
01 REG-LOG PIC X(250).

WORKING-STORAGE SECTION.
01 FS-TRANSACOES             PIC XX VALUE SPACES.
01 WS-FIM-TRANSACOES         PIC X VALUE "N".
01 WS-LINHA                  PIC X(250) VALUE SPACES.
01 WS-DESCRICAO-ERRO         PIC X(100) VALUE SPACES.
01 WS-STATUS-HISTORICO       PIC X(30) VALUE SPACES.

01 WS-VALORES.
   05 WS-SALDO-ANTERIOR      PIC 9(09) VALUE ZERO.
   05 WS-SALDO-NOVO          PIC 9(09) VALUE ZERO.
   05 WS-VALOR-TRANSACAO     PIC 9(09) VALUE ZERO.
   05 WS-SALDO-ANTERIOR-TXT  PIC X(09) VALUE ZEROES.
   05 WS-SALDO-NOVO-TXT      PIC X(09) VALUE ZEROES.

01 WS-CONTADORES.
   05 WS-TOTAL-LIDOS         PIC 9(06) VALUE ZERO.
   05 WS-TOTAL-PROCESSADOS   PIC 9(06) VALUE ZERO.
   05 WS-TOTAL-ERROS         PIC 9(06) VALUE ZERO.
   05 WS-TOTAL-CREDITOS      PIC 9(06) VALUE ZERO.
   05 WS-TOTAL-DEBITOS       PIC 9(06) VALUE ZERO.
   05 WS-CONTADOR-COMMIT     PIC 9(03) VALUE ZERO.

01 WS-TOTAIS-EDITADOS.
   05 WS-TOTAL-LIDOS-ED      PIC ZZZZZ9.
   05 WS-TOTAL-PROC-ED       PIC ZZZZZ9.
   05 WS-TOTAL-ERROS-ED      PIC ZZZZZ9.
   05 WS-TOTAL-CREDITOS-ED   PIC ZZZZZ9.
   05 WS-TOTAL-DEBITOS-ED    PIC ZZZZZ9.

COPY "variaveis_banco.cpy".

PROCEDURE DIVISION.
INICIO.
    PERFORM ABRIR-ARQUIVOS
    PERFORM CONECTAR-BANCO
    PERFORM PROCESSAR-ARQUIVO UNTIL WS-FIM-TRANSACOES = "S"
    PERFORM FINALIZAR-BANCO
    PERFORM GRAVAR-RELATORIO
    PERFORM FECHAR-ARQUIVOS
    STOP RUN.

ABRIR-ARQUIVOS.
    OPEN INPUT ARQ-TRANSACOES
    OPEN OUTPUT ARQ-STATUS ARQ-DETALHADO ARQ-RELATORIO ARQ-ERROS ARQ-LOG

    MOVE "INICIO DO PROCESSAMENTO DE TRANSACOES" TO WS-LINHA
    WRITE REG-LOG FROM WS-LINHA

    MOVE "CLIENTE TRANSACAO TIPO VALOR     STATUS" TO WS-LINHA
    WRITE REG-DETALHADO FROM WS-LINHA
    MOVE "======= ========= ==== ========= ==============================" TO WS-LINHA
    WRITE REG-DETALHADO FROM WS-LINHA

    IF FS-TRANSACOES NOT = "00"
        MOVE "ERRO AO ABRIR entrada/TRANSACOES_ORD.TXT" TO WS-LINHA
        WRITE REG-LOG FROM WS-LINHA
        MOVE "S" TO WS-FIM-TRANSACOES
    END-IF.

CONECTAR-BANCO.
    CALL "BANCO_CONECTAR" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
    MOVE SPACES TO WS-LINHA
    STRING "DB2: " WS-MSG-BANCO DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-LOG FROM WS-LINHA

    IF WS-RC-BANCO NOT = ZERO
        MOVE "S" TO WS-FIM-TRANSACOES
        MOVE "FALHA NA CONEXAO COM DB2" TO WS-LINHA
        WRITE REG-LOG FROM WS-LINHA
    END-IF.

PROCESSAR-ARQUIVO.
    READ ARQ-TRANSACOES
        AT END
            MOVE "S" TO WS-FIM-TRANSACOES
        NOT AT END
            ADD 1 TO WS-TOTAL-LIDOS
            PERFORM PROCESSAR-UMA-TRANSACAO
    END-READ.

PROCESSAR-UMA-TRANSACAO.
    MOVE SPACES TO WS-DESCRICAO-ERRO
    MOVE ZERO TO WS-SALDO-ANTERIOR WS-SALDO-NOVO WS-VALOR-TRANSACAO
    MOVE ZEROES TO WS-SALDO-ANTERIOR-TXT WS-SALDO-NOVO-TXT

    PERFORM VALIDAR-CAMPOS-BASICOS

    IF WS-DESCRICAO-ERRO NOT = SPACES
        PERFORM REGISTRAR-ERRO-TRANSACAO
    ELSE
        MOVE TRX-ARQ-VALOR TO WS-VALOR-TRANSACAO

        CALL "BANCO_OBTER_SALDO" USING
            TRX-ARQ-CLI-ID
            WS-SALDO-ANTERIOR-TXT
            WS-MSG-BANCO
            RETURNING WS-RC-BANCO
        END-CALL

        IF WS-RC-BANCO = 100
            MOVE "CLIENTE INEXISTENTE" TO WS-DESCRICAO-ERRO
            PERFORM REGISTRAR-ERRO-TRANSACAO
        ELSE
            IF WS-RC-BANCO NOT = ZERO
                MOVE "ERRO SQL AO CONSULTAR SALDO" TO WS-DESCRICAO-ERRO
                PERFORM REGISTRAR-ERRO-SQL
            ELSE
                MOVE WS-SALDO-ANTERIOR-TXT TO WS-SALDO-ANTERIOR
                PERFORM VALIDAR-SALDO-E-EFETIVAR
            END-IF
        END-IF
    END-IF.

VALIDAR-CAMPOS-BASICOS.
    IF TRX-ARQ-CLI-ID IS NOT NUMERIC
        MOVE "ID DO CLIENTE INVALIDO" TO WS-DESCRICAO-ERRO
    END-IF

    IF TRX-ARQ-ID IS NOT NUMERIC
        MOVE "ID DA TRANSACAO INVALIDO" TO WS-DESCRICAO-ERRO
    END-IF

    IF TRX-ARQ-VALOR IS NOT NUMERIC
        MOVE "VALOR DA TRANSACAO INVALIDO" TO WS-DESCRICAO-ERRO
    END-IF

    IF TRX-ARQ-TIPO NOT = "C" AND TRX-ARQ-TIPO NOT = "D"
        MOVE "TIPO INVALIDO" TO WS-DESCRICAO-ERRO
    END-IF

    IF TRX-ARQ-VALOR IS NUMERIC
        IF TRX-ARQ-VALOR = "000000000"
            MOVE "VALOR ZERADO" TO WS-DESCRICAO-ERRO
        END-IF
    END-IF.

VALIDAR-SALDO-E-EFETIVAR.
    IF TRX-ARQ-TIPO = "D" AND WS-VALOR-TRANSACAO > WS-SALDO-ANTERIOR
        MOVE "SALDO INSUFICIENTE" TO WS-DESCRICAO-ERRO
        PERFORM REGISTRAR-ERRO-TRANSACAO
    ELSE
        IF TRX-ARQ-TIPO = "C"
            COMPUTE WS-SALDO-NOVO = WS-SALDO-ANTERIOR + WS-VALOR-TRANSACAO
        ELSE
            COMPUTE WS-SALDO-NOVO = WS-SALDO-ANTERIOR - WS-VALOR-TRANSACAO
        END-IF

        MOVE WS-SALDO-NOVO TO WS-SALDO-NOVO-TXT
        PERFORM GRAVAR-TRANSACAO-NO-BANCO
    END-IF.

GRAVAR-TRANSACAO-NO-BANCO.
    CALL "BANCO_INSERIR_TRANSACAO" USING
        TRX-ARQ-ID
        TRX-ARQ-CLI-ID
        TRX-ARQ-TIPO
        TRX-ARQ-VALOR
        WS-MSG-BANCO
        RETURNING WS-RC-BANCO
    END-CALL

    IF WS-RC-BANCO NOT = ZERO
        MOVE "ERRO SQL AO INSERIR TRANSACAO" TO WS-DESCRICAO-ERRO
        PERFORM REGISTRAR-ERRO-SQL
    ELSE
        CALL "BANCO_ATUALIZAR_SALDO" USING
            TRX-ARQ-CLI-ID
            WS-SALDO-NOVO-TXT
            WS-MSG-BANCO
            RETURNING WS-RC-BANCO
        END-CALL

        IF WS-RC-BANCO NOT = ZERO
            MOVE "ERRO SQL AO ATUALIZAR SALDO" TO WS-DESCRICAO-ERRO
            PERFORM REGISTRAR-ERRO-SQL
        ELSE
            ADD 1 TO WS-TOTAL-PROCESSADOS
            IF TRX-ARQ-TIPO = "C"
                ADD 1 TO WS-TOTAL-CREDITOS
            ELSE
                ADD 1 TO WS-TOTAL-DEBITOS
            END-IF
            MOVE "PROCESSADA" TO WS-STATUS-HISTORICO
            MOVE "TRANSACAO EFETIVADA" TO WS-DESCRICAO-ERRO
            PERFORM REGISTRAR-HISTORICO
            PERFORM GRAVAR-STATUS-SUCESSO
            PERFORM CONTROLAR-COMMIT
        END-IF
    END-IF.

REGISTRAR-ERRO-TRANSACAO.
    ADD 1 TO WS-TOTAL-ERROS
    MOVE "ERRO" TO WS-STATUS-HISTORICO

    MOVE SPACES TO WS-LINHA
    STRING "TRANSACAO " TRX-ARQ-ID
           " CLIENTE " TRX-ARQ-CLI-ID
           " - ERRO: " WS-DESCRICAO-ERRO
           DELIMITED BY SIZE INTO WS-LINHA
    END-STRING
    WRITE REG-ERROS FROM WS-LINHA
    WRITE REG-STATUS FROM WS-LINHA
    WRITE REG-DETALHADO FROM WS-LINHA

    IF TRX-ARQ-CLI-ID IS NUMERIC
        CALL "BANCO_REGISTRAR_ERRO" USING
            TRX-ARQ-CLI-ID
            WS-DESCRICAO-ERRO
            WS-MSG-BANCO
            RETURNING WS-RC-BANCO
        END-CALL
        PERFORM REGISTRAR-HISTORICO
        PERFORM CONTROLAR-COMMIT
    END-IF.

REGISTRAR-ERRO-SQL.
    ADD 1 TO WS-TOTAL-ERROS

    MOVE SPACES TO WS-LINHA
    STRING "TRANSACAO " TRX-ARQ-ID
           " CLIENTE " TRX-ARQ-CLI-ID
           " - ERRO SQL: " WS-DESCRICAO-ERRO
           DELIMITED BY SIZE INTO WS-LINHA
    END-STRING
    WRITE REG-ERROS FROM WS-LINHA
    WRITE REG-STATUS FROM WS-LINHA
    WRITE REG-LOG FROM WS-LINHA

    CALL "BANCO_ROLLBACK" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
    MOVE ZERO TO WS-CONTADOR-COMMIT.

REGISTRAR-HISTORICO.
    IF WS-SALDO-ANTERIOR-TXT = ZEROES
        MOVE WS-SALDO-ANTERIOR TO WS-SALDO-ANTERIOR-TXT
    END-IF
    IF WS-SALDO-NOVO-TXT = ZEROES
        MOVE WS-SALDO-NOVO TO WS-SALDO-NOVO-TXT
    END-IF

    CALL "BANCO_REGISTRAR_HISTORICO" USING
        TRX-ARQ-ID
        TRX-ARQ-CLI-ID
        TRX-ARQ-TIPO
        TRX-ARQ-VALOR
        WS-SALDO-ANTERIOR-TXT
        WS-SALDO-NOVO-TXT
        WS-STATUS-HISTORICO
        WS-DESCRICAO-ERRO
        WS-MSG-BANCO
        RETURNING WS-RC-BANCO
    END-CALL.

GRAVAR-STATUS-SUCESSO.
    MOVE SPACES TO WS-LINHA
    STRING TRX-ARQ-CLI-ID "    " TRX-ARQ-ID "     " TRX-ARQ-TIPO
           "    " TRX-ARQ-VALOR " PROCESSADA COM SUCESSO"
           DELIMITED BY SIZE INTO WS-LINHA
    END-STRING
    WRITE REG-STATUS FROM WS-LINHA
    WRITE REG-DETALHADO FROM WS-LINHA.

CONTROLAR-COMMIT.
    ADD 1 TO WS-CONTADOR-COMMIT
    IF WS-CONTADOR-COMMIT >= 100
        CALL "BANCO_COMMIT" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
        MOVE ZERO TO WS-CONTADOR-COMMIT
        MOVE "COMMIT AUTOMATICO A CADA 100 REGISTROS" TO WS-LINHA
        WRITE REG-LOG FROM WS-LINHA
    END-IF.

FINALIZAR-BANCO.
    CALL "BANCO_COMMIT" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL
    MOVE SPACES TO WS-LINHA
    STRING "DB2 FINAL TRANSACOES: " WS-MSG-BANCO
           DELIMITED BY SIZE INTO WS-LINHA
    END-STRING
    WRITE REG-LOG FROM WS-LINHA

    CALL "BANCO_DESCONECTAR" USING WS-MSG-BANCO RETURNING WS-RC-BANCO END-CALL.

GRAVAR-RELATORIO.
    MOVE WS-TOTAL-LIDOS TO WS-TOTAL-LIDOS-ED
    MOVE WS-TOTAL-PROCESSADOS TO WS-TOTAL-PROC-ED
    MOVE WS-TOTAL-ERROS TO WS-TOTAL-ERROS-ED
    MOVE WS-TOTAL-CREDITOS TO WS-TOTAL-CREDITOS-ED
    MOVE WS-TOTAL-DEBITOS TO WS-TOTAL-DEBITOS-ED

    MOVE "RELATORIO DE PROCESSAMENTO - TRANSACOES" TO WS-LINHA
    WRITE REG-RELATORIO FROM WS-LINHA
    MOVE "=======================================" TO WS-LINHA
    WRITE REG-RELATORIO FROM WS-LINHA

    MOVE SPACES TO WS-LINHA
    STRING "TOTAL LIDOS:       " WS-TOTAL-LIDOS-ED DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-RELATORIO FROM WS-LINHA

    MOVE SPACES TO WS-LINHA
    STRING "TOTAL PROCESSADOS: " WS-TOTAL-PROC-ED DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-RELATORIO FROM WS-LINHA

    MOVE SPACES TO WS-LINHA
    STRING "TOTAL COM ERRO:    " WS-TOTAL-ERROS-ED DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-RELATORIO FROM WS-LINHA

    MOVE SPACES TO WS-LINHA
    STRING "TOTAL CREDITOS:    " WS-TOTAL-CREDITOS-ED DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-RELATORIO FROM WS-LINHA

    MOVE SPACES TO WS-LINHA
    STRING "TOTAL DEBITOS:     " WS-TOTAL-DEBITOS-ED DELIMITED BY SIZE INTO WS-LINHA END-STRING
    WRITE REG-RELATORIO FROM WS-LINHA.

FECHAR-ARQUIVOS.
    CLOSE ARQ-TRANSACOES ARQ-STATUS ARQ-DETALHADO ARQ-RELATORIO ARQ-ERROS ARQ-LOG.

END PROGRAM PROCESSAR-TRANSACOES.
